{
  "hrrr": {
    "cache_dir": ".cache/hrrr",
    "domain": "conus",
    "product": "wrfprsf",
    "use_s3fs": true,
    "http_fallback": true,
    "download_workers": 6,
    "local_grib_dir": null,
    "keep_downloaded_files": true
  },
  "grid": {
    "half_width_east_m": 200000.0,
    "half_width_north_m": 200000.0,
    "min_altitude_m": -1000.0,
    "max_altitude_m": 32000.0,
    "nx": 96,
    "ny": 96,
    "nz": 72,
    "gradient_step_m": 25.0,
    "wind_projection_mode": "heading"
  },
  "aircraft": {
    "mach": 1.05,
    "constant_altitude_m": 16500.0,
    "reference_sound_speed_mps": 340.29
  },
  "shock": {
    "emission_interval_s": 60.0,
    "rays_per_emission": 48,
    "downward_only": true,
    "azimuth_offset_deg": 0.0,
    "direction_reference": "aircraft_aft"
  },
  "raytrace": {
    "ds_m": 200.0,
    "max_steps": 4000,
    "adaptive": true,
    "tol": 0.0005,
    "min_step_m": 15.0,
    "max_step_m": 900.0,
    "stop_on_exit": true
  },
  "runtime": {
    "start_time_iso": null,
    "end_time_iso": null,
    "max_emissions": null,
    "ray_batch_size": 0
  },
  "population": {
    "enabled": true,
    "dataset_path": null,
    "heatmap_cell_deg": 0.12,
    "hit_radius_km": 25.0,
    "trace_half_width_km": 12.0,
    "max_segment_length_km": 220.0,
    "domain_pad_deg": 0.8,
    "max_grid_cells": 600000
  },
  "visualization": {
    "enable_matplotlib": true,
    "enable_plotly": true,
    "enable_pyvista": false,
    "output_dir": "tmp/outputs_full_groundhits_nonfalcon",
    "make_animation": false,
    "write_html": true,
    "include_atmosphere": true,
    "map_style": "topographic"
  }
}

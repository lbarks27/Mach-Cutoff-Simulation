  },
  "population": {
    "enabled": true,
    "dataset_path": null,
    "heatmap_cell_deg": 0.1,
    "hit_radius_km": 80.0,
    "trace_half_width_km": 14.0
  },
  "route_optimization": {
    "enabled": true,
    "max_wall_time_s": 240.0,
    "reserve_time_for_full_fidelity_s": 55.0,
    "seed": 17,
    "batch_size": 4,
    "finalists": 2,
    "min_control_waypoints": 11,
    "enable_fuel_objective": true,
    "weight_population": 3.5,
    "weight_speed": 1.8,
    "weight_fuel": 0.015,
    "weight_populated_ground_hits": 24.0,
    "weight_total_ground_hits": 0.08,
    "unpopulated_speed_weight_bonus": 3.2,
    "min_fuel_weight_scale": 0.0,

{
  "hrrr": {
    "cache_dir": ".cache/hrrr",
    "domain": "conus",
    "product": "wrfprsf",
    "use_s3fs": true,
    "http_fallback": true,
    "download_workers": 8,
    "local_grib_dir": null,
    "keep_downloaded_files": true
  },
  "grid": {
    "half_width_east_m": 200000.0,

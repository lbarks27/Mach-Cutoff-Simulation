  "visualization": {
    "enable_matplotlib": false,
    "enable_plotly": false,
    "enable_pyvista": false,
    "output_dir": "outputs_tuning_fast",
    "make_animation": false,
    "write_html": false,
    "include_atmosphere": false,
    "map_style": "topographic"

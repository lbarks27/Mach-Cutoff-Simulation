{
  "hrrr": {
    "cache_dir": ".cache/hrrr",
    "domain": "conus",
    "product": "wrfprsf",
    "use_s3fs": true,
    "http_fallback": true,
    "download_workers": 6,
    "local_grib_dir": null,
    "keep_downloaded_files": true
  },
  "grid": {
    "half_width_east_m": 240000.0,
    "half_width_north_m": 240000.0,
    "min_altitude_m": -500.0,
    "max_altitude_m": 60000.0,
    "nx": 64,
    "ny": 64,
    "nz": 48,
    "gradient_step_m": 75.0,
    "wind_projection_mode": "heading"
  },
  "aircraft": {
    "mach": 2.6,
    "constant_altitude_m": 45000.0,
    "reference_sound_speed_mps": 340.29
  },
  "shock": {
    "emission_interval_s": 1.0,
    "rays_per_emission": 20,
    "downward_only": true,
    "azimuth_offset_deg": 0.0,
    "direction_reference": "aircraft_forward"
  },
  "raytrace": {
    "ds_m": 450.0,
    "max_steps": 3000,
    "adaptive": true,
    "tol": 0.001,
    "min_step_m": 60.0,
    "max_step_m": 2500.0,
    "stop_on_exit": true
  },
  "runtime": {
    "start_time_iso": null,
    "end_time_iso": null,
    "max_emissions": null,
    "ray_batch_size": 0
  },
  "visualization": {
    "enable_matplotlib": false,
    "enable_plotly": false,
    "enable_pyvista": false,
    "output_dir": "outputs_falcon9_lz1_noguidance",
    "make_animation": false,
    "write_html": false,
    "include_atmosphere": false,
    "map_style": "satellite"
  }
}
